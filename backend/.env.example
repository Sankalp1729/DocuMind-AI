DOCUMIND_OLLAMA_BASE_URL=http://ollama:11434
DOCUMIND_OLLAMA_MODEL=llama3
DOCUMIND_TOP_K=3
DOCUMIND_LOG_LEVEL=INFO
DOCUMIND_STREAMING_TIMEOUT_SECONDS=180
DOCUMIND_STREAMING_BUFFER_SIZE=4
DOCUMIND_DATABASE_URL=sqlite:///data/documind.db
DOCUMIND_REDIS_URL=redis://redis:6379/0
DOCUMIND_ADMIN_API_KEY=change-me
DOCUMIND_ENABLE_AUTH=false
DOCUMIND_ENABLE_RATE_LIMITING=true
DOCUMIND_ENABLE_CONVERSATION_PERSISTENCE=true
DOCUMIND_ENABLE_METRICS=true
DOCUMIND_ENABLE_ADMIN_ENDPOINTS=true
DOCUMIND_ENABLE_HYBRID_RETRIEVAL=false